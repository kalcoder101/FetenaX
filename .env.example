# FetenaX Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_ENV=development              # development | production
ALLOW_SIGNUP=true                # true | false (set to false in production)

# Database
DB_HOST=localhost                # MySQL host (e.g., sql208.infinityfree.com)
DB_PORT=3306                     # MySQL port (3306 is standard)
DB_USER=your_db_username         # MySQL username
DB_PASS=your_db_password         # MySQL password
DB_NAME=your_db_name             # MySQL database name

# Migration (set to false in production to skip schema/seed on every request)
DB_AUTO_MIGRATE=true             # true | false
