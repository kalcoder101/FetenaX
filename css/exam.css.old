/* ============================
   EXAM — Taking Interface, Results Page, Practice Mode, Exam Creation
   ============================ */

/* === EXAM TAKING INTERFACE === */

/* Fixed full-viewport, no body scroll during exam */
.exam-interface {
    position: fixed;
    top: 0; left: 0;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: var(--color-bg);
    z-index: 5000;
    display: flex;
    flex-direction: column;
    padding: 0;
}
.exam-interface .container {
    flex: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-width: 1280px;
    padding: 0.9rem 1.2rem;
    height: 100%;
}
.exam-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
}
.exam-header h2 { font-size: 1.5rem; font-weight: 600; color: var(--color-text); }
.timer {
    background: var(--color-card);
    color: var(--color-text);
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 1.125rem;
}

/* --- Header strip with timer --- */
.exam-header-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--color-card);
    border-radius: 0.75rem;
    box-shadow: var(--color-shadow);
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    border: 1.5px solid var(--color-border);
    flex-shrink: 0;
}
.exam-header-left h2 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-primary);
}
.exam-timer-box {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1.5px solid #ef4444;
    color: #ef4444;
    background: rgba(239, 68, 68, 0.04);
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-weight: 700;
    font-size: 1.15rem;
}
.exam-timer-box.timer-warning {
    background: rgba(239, 68, 68, 0.15);
    animation: pulseRed 1s infinite alternate;
}
@keyframes pulseRed {
    from { opacity: 0.8; }
    to { opacity: 1; transform: scale(1.02); }
}
.timer-label { font-size: 0.85rem; text-transform: uppercase; }

/* --- Double panel workspace --- */
.exam-workspace {
    display: flex;
    gap: 1.2rem;
    align-items: stretch;
    flex: 1;
    min-height: 0;
    overflow: hidden;
}
.exam-main-panel {
    flex: 1;
    display: flex;
    gap: 1.2rem;
    background: var(--color-card);
    border-radius: 0.8rem;
    box-shadow: var(--color-shadow);
    padding: 1.2rem 1.5rem;
    border: 1.5px solid var(--color-border);
    overflow: hidden;
    min-height: 0;
}

/* Left sub-column: Candidate Info */
.exam-info-card {
    width: 170px;
    flex-shrink: 0;
    border-right: 1.5px solid var(--color-border);
    padding-right: 1.5rem;
}
.candidate-photo {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    margin: 0 auto 1.2rem auto;
}
.candidate-details {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
}
.detail-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.detail-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.4rem;
    word-break: break-word;
}

/* Right sub-column: Question & Options */
.exam-content-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    min-height: 0;
}
.question-header-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1.5px solid var(--color-border);
    padding-bottom: 0.6rem;
    margin-bottom: 1.2rem;
}
.question-number-label { font-size: 1rem; font-weight: 700; color: var(--color-primary); }
.question-points { font-size: 0.85rem; color: var(--color-text-secondary); font-weight: 600; }

.question-text {
    font-size: 1.08rem;
    font-weight: 600;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    color: var(--color-text);
}
.options-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}
.option-item {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--color-border);
    border-radius: 0.6rem;
    padding: 0.9rem 1.2rem;
    cursor: pointer;
    background: var(--color-bg);
    transition: all 0.18s ease;
    user-select: none;
    font-size: 1rem;
    color: var(--color-text);
}
.option-item:hover {
    border-color: var(--color-primary);
    background: rgba(87,120,90,0.06);
}
.option-item.selected {
    border-color: var(--color-primary);
    background: rgba(87,120,90,0.1);
    font-weight: 600;
}
.option-item input[type="radio"] { display: none; }
.option-letter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px; height: 26px;
    border-radius: 50%;
    border: 1.5px solid var(--color-text-secondary);
    font-weight: 700;
    font-size: 0.85rem;
    margin-right: 1rem;
    flex-shrink: 0;
    transition: all 0.15s ease;
}
.option-item.selected .option-letter {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
}
.option-text-content { flex: 1; }

/* Controls row */
.exam-nav-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.8rem;
    border-top: 1.5px solid var(--color-border);
    padding-top: 1.2rem;
}

/* Right column: Navigation panel */
.exam-navigation-panel {
    width: 240px;
    flex-shrink: 0;
    background: var(--color-card);
    border-radius: 0.8rem;
    box-shadow: var(--color-shadow);
    padding: 1rem 1rem;
    border: 1.5px solid var(--color-border);
    overflow-y: auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
}
.navigation-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1.2rem;
    border-bottom: 1.5px solid var(--color-border);
    padding-bottom: 0.5rem;
}
.questions-grid-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.6rem;
    margin-bottom: 1.5rem;
}
.grid-cell-btn {
    position: relative;
    aspect-ratio: 1.05;
    border-radius: 0.4rem;
    border: 1.5px solid var(--color-border);
    background: var(--color-bg);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: all 0.15s ease;
    outline: none;
}
.grid-cell-btn:hover { border-color: var(--color-primary); }
.grid-cell-btn.active {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.25);
    background: var(--color-card);
}
.grid-cell-btn .cell-num {
    position: relative;
    z-index: 5;
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text);
}
.grid-cell-btn.answered .cell-shading {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 50%;
    background: #6b7280;
    z-index: 1;
}
.grid-cell-btn.answered.active .cell-shading { background: #4b5563; }
.grid-cell-btn.flagged .cell-flag-dot {
    position: absolute;
    top: 4px; right: 4px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #f59e0b;
    z-index: 6;
    box-shadow: 0 0 2px rgba(0,0,0,0.3);
}

/* Legend */
.grid-legend {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1.5px solid var(--color-border);
    padding-top: 1rem;
}
.legend-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-secondary);
}
.legend-color {
    width: 16px; height: 16px;
    border-radius: 3px;
    border: 1.5px solid var(--color-border);
    display: inline-block;
    flex-shrink: 0;
}
.legend-active {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1.5px rgba(59, 130, 246, 0.25);
}
.legend-answered { position: relative; background: var(--color-bg); overflow: hidden; }
.legend-answered::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 50%;
    background: #6b7280;
}
.legend-flagged { position: relative; }
.legend-flagged::after {
    content: '';
    position: absolute;
    top: 3px; right: 3px;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #f59e0b;
}

/* --- Practice mode option feedback --- */
.option-item.practice-correct {
    border-color: var(--color-success) !important;
    background: rgba(110,154,114,0.12) !important;
}
.option-item.practice-wrong {
    border-color: var(--color-danger) !important;
    background: rgba(224,122,95,0.10) !important;
}
.option-item.practice-correct .option-letter {
    background: var(--color-success) !important;
    color: #fff !important;
    border-color: var(--color-success) !important;
}
.option-item.practice-wrong .option-letter {
    background: var(--color-danger) !important;
    color: #fff !important;
    border-color: var(--color-danger) !important;
}

/* === RESULTS PAGE === */

.results-page {
    position: fixed;
    top: 0; left: 0;
    width: 100vw; height: 100vh;
    z-index: 10000;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: stretch;
    overflow: hidden;
    padding: 0;
}
.results-page.hidden { display: none !important; }

/* Sticky header */
.results-page-header {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.85rem 1.4rem;
    background: var(--color-card);
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
    z-index: 10;
}
.results-back-btn {
    width: 38px; height: 38px;
    border-radius: 0.55rem;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    flex-shrink: 0;
}
.results-back-btn:hover {
    background: rgba(87,120,90,0.08);
    color: var(--color-primary);
    border-color: var(--color-primary);
}
.results-page-title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--color-text);
    font-family: 'Plus Jakarta Sans', sans-serif;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.results-page-title svg { color: var(--color-primary); }
.results-header-spacer { flex: 1; }

/* Scrollable content area */
.results-outer-scroll {
    flex: 1;
    width: 100%;
    max-width: 780px;
    margin: 0 auto;
    overflow-y: auto;
    padding: 1.5rem 1.5rem 3rem;
}
.results-container {
    background: var(--color-card);
    border-radius: 0.85rem;
    padding: 1.6rem 1.4rem;
    text-align: left;
    color: var(--color-text);
    border: 1px solid var(--color-border);
}

/* Hero: score ring + info */
.results-hero {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.5rem 0.5rem 1.2rem 0.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.2rem;
    flex-wrap: wrap;
}
@media (max-width: 560px) {
    .results-hero { flex-direction: column; text-align: center; gap: 0.85rem; }
}
.results-score-ring-wrap {
    position: relative;
    width: 150px; height: 150px;
    flex-shrink: 0;
}
.score-ring-svg {
    width: 150px; height: 150px;
    transform: rotate(-90deg);
}
.score-ring-track {
    fill: none;
    stroke: var(--color-border);
    stroke-width: 14;
}
.score-ring-fill {
    fill: none;
    stroke: var(--color-primary);
    stroke-width: 14;
    stroke-linecap: round;
    stroke-dasharray: 515;
    stroke-dashoffset: 515;
    transition: stroke-dashoffset 1s cubic-bezier(.4,0,.2,1), stroke 0.4s;
}
.score-ring-fill.ring-pass { stroke: var(--color-success); }
.score-ring-fill.ring-fail { stroke: var(--color-danger); }
.score-ring-inner {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
}
.score-ring-pct { font-size: 2.2rem; font-weight: 800; color: var(--color-text); line-height: 1; }
.score-ring-lbl {
    font-size: 0.74rem; font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 3px;
}
.results-hero-info {
    flex: 1;
    min-width: 220px;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: flex-start;
}
@media (max-width: 560px) { .results-hero-info { align-items: center; } }
.results-exam-title {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0;
    line-height: 1.25;
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
}
.results-subtitle { font-size: 0.88rem; color: var(--color-text-secondary); line-height: 1.45; margin: 0; }

/* Pass/Fail badge */
.pass-badge {
    display: inline-block;
    padding: 0.28rem 0.95rem;
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin: 0;
    align-self: flex-start;
}
@media (max-width: 560px) { .pass-badge { align-self: center; } }
.pass-badge.badge-pass {
    background: rgba(110,154,114,0.14);
    color: var(--color-success);
    border: 1.5px solid var(--color-success);
}
.pass-badge.badge-fail {
    background: rgba(224,122,95,0.12);
    color: var(--color-danger);
    border: 1.5px solid var(--color-danger);
}

/* STATS GRID (4 cards) */
.results-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.7rem;
    margin-bottom: 1rem;
}
@media (max-width: 560px) { .results-stats-grid { grid-template-columns: repeat(2, 1fr); } }
.result-stat-card {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 0.7rem;
    padding: 0.7rem 0.85rem;
}
.rsc-icon {
    width: 34px; height: 34px;
    border-radius: 0.55rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.rsc-icon-correct   { background: rgba(46,204,113,0.15);  color: var(--color-success); }
.rsc-icon-time      { background: rgba(52,152,219,0.15);  color: #3498db; }
.rsc-icon-questions { background: rgba(87,120,90,0.15);   color: var(--color-primary); }
.rsc-icon-points    { background: rgba(245,158,11,0.15);  color: #f59e0b; }
.rsc-body { flex: 1; min-width: 0; }
.rsc-val { font-size: 1.1rem; font-weight: 800; color: var(--color-text); line-height: 1.1; }
.rsc-lbl {
    font-size: 0.7rem; color: var(--color-text-secondary);
    font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; margin-top: 2px;
}

/* Performance breakdown */
.results-summary-card {
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 0.7rem;
    padding: 0.85rem 1rem;
    margin-bottom: 1rem;
}
.rsc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.6rem;
}
.rsc-header h3 { font-size: 0.85rem; font-weight: 700; color: var(--color-text); margin: 0; text-transform: uppercase; }
.rsc-pct-text { font-size: 1.05rem; font-weight: 800; color: var(--color-primary); }
.results-breakdown-bar {
    display: flex;
    height: 14px;
    border-radius: 99px;
    overflow: hidden;
    background: var(--color-border);
    margin-bottom: 0.55rem;
}
.bd-seg { height: 100%; transition: width 0.5s cubic-bezier(.4,0,.2,1); min-width: 0; }
.bd-correct     { background: var(--color-success); }
.bd-wrong       { background: var(--color-danger); }
.bd-unanswered  { background: rgba(150,150,150,0.55); }
.results-breakdown-legend {
    display: flex; gap: 1rem; flex-wrap: wrap;
    font-size: 0.78rem; color: var(--color-text-secondary);
}
.bd-legend-item { display: flex; align-items: center; gap: 0.35rem; font-weight: 600; }
.bd-dot { width: 9px; height: 9px; border-radius: 50%; display: inline-block; }

/* Answer review */
.answer-review-section { text-align: left; margin-bottom: 1.2rem; }
.answer-review-header {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.88rem; font-weight: 700; color: var(--color-text);
    text-transform: uppercase; letter-spacing: 0.06em;
    border-bottom: 1.5px solid var(--color-border);
    padding-bottom: 0.55rem; margin-bottom: 0.75rem;
}
.answer-review-header svg { color: var(--color-primary); flex-shrink: 0; }
.answer-review-count {
    margin-left: auto;
    font-size: 0.72rem; font-weight: 600; color: var(--color-text-secondary);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.15rem 0.5rem; border-radius: 99px;
    text-transform: none; letter-spacing: 0;
}
.answer-review-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 360px;
    overflow-y: auto;
    padding-right: 2px;
}

/* Answer review cards (v2) */
.ar-card {
    padding: 0.7rem 0.85rem;
    border-radius: 0.55rem;
    border: 1.5px solid transparent;
    font-size: 0.85rem;
    background: var(--glass-bg);
}
.ar-card.ar-correct {
    background: rgba(110,154,114,0.09);
    border-color: rgba(110,154,114,0.3);
}
.ar-card.ar-wrong {
    background: rgba(224,122,95,0.09);
    border-color: rgba(224,122,95,0.3);
}
.ar-card.ar-unanswered {
    background: rgba(150,150,150,0.06);
    border-color: rgba(150,150,150,0.2);
}
.ar-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.3rem;
}
.ar-num { font-size: 0.75rem; font-weight: 700; color: var(--color-text-secondary); }
.ar-status-icon { font-size: 0.85rem; font-weight: 800; }
.ar-points { font-size: 0.68rem; font-weight: 700; margin-left: auto; }
.ar-card.ar-correct .ar-points { color: var(--color-success); }
.ar-card.ar-wrong .ar-points { color: var(--color-danger); }
.ar-question { font-weight: 600; color: var(--color-text); margin-bottom: 0.35rem; }
.ar-answers { font-size: 0.8rem; }
.ar-your-ans { color: var(--color-danger); }
.ar-correct-answer { color: var(--color-success); }
.ar-card.ar-correct .ar-your-ans { color: var(--color-success); }

/* Action buttons */
.results-actions {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 0.55rem;
    margin-top: 0.3rem;
}
@media (max-width: 560px) { .results-actions { grid-template-columns: 1fr; } }
.results-action-btn {
    padding: 0.75rem 0.85rem !important;
    font-size: 0.9rem !important;
    font-weight: 700 !important;
    border-radius: 0.65rem !important;
    justify-content: center;
}

/* Results badges row */
.results-badges-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.4rem;
}

/* === CREATE EXAM MODAL === */

/* Full-page overlay without .modal-content constraints */
.create-exam-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 12000;
    background: rgba(19, 29, 22, 0.25);
    backdrop-filter: blur(12px) saturate(1.2);
    overflow-y: auto;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 1rem;
}
.create-exam-fullpage {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 1.5rem;
    box-shadow: var(--color-shadow);
    width: 100%;
    max-width: 960px;
    margin: 1.5rem auto;
    overflow: hidden;
    display: flex;
    flex-direction: column;
}
.cefp-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
    gap: 0.75rem;
}
.cefp-header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}
.cefp-back-btn {
    width: 36px; height: 36px;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    flex-shrink: 0;
}
.cefp-back-btn:hover {
    background: rgba(87,120,90,0.08);
    color: var(--color-primary);
    border-color: var(--color-primary);
}
.cefp-header-left h3 {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.4rem;
}
.cefp-subtitle { font-size: 0.82rem; color: var(--color-text-secondary); }
.cefp-header-right {
    display: flex;
    gap: 0.5rem;
}
.cefp-body { padding: 1.5rem; overflow-y: auto; max-height: 70vh; }
.cefp-grid {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 1.5rem;
    align-items: start;
}
.cefp-main-col { min-width: 0; }
.cefp-summary-col { position: sticky; top: 0; }

/* Sections inside create exam */
.cefp-section {
    margin-bottom: 1.25rem;
    background: var(--glass-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 0.85rem;
    padding: 1.2rem;
}
.cefp-section-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1rem;
}
.cefp-section-num {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.82rem;
    flex-shrink: 0;
}
.cefp-section-title { font-size: 0.95rem; font-weight: 700; color: var(--color-text); }
.cefp-section-desc { font-size: 0.78rem; color: var(--color-text-secondary); }
.cefp-section-actions {
    margin-left: auto;
    display: flex;
    gap: 0.5rem;
    align-items: center;
}

/* Form grid */
.cefp-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
}
.cefp-span-2 { grid-column: 1 / -1; }
.cefp-form-grid .form-group { display: flex; flex-direction: column; }
.cefp-form-grid .form-group label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    margin-bottom: 0.25rem;
}
.req { color: var(--color-danger); }

/* Toggle rows for options */
.cefp-options-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}
.cefp-toggle-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.65rem;
    border-radius: 0.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: background 0.15s;
}
.cefp-toggle-row:hover { background: rgba(87,120,90,0.05); }
.cefp-toggle-row input[type="checkbox"] { accent-color: var(--color-primary); width: 16px; height: 16px; }
.cefp-toggle-label { font-size: 0.88rem; font-weight: 600; color: var(--color-text); display: block; }
.cefp-toggle-desc { font-size: 0.74rem; color: var(--color-text-secondary); }
.cefp-num-field {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.65rem;
}
.cefp-num-field label { font-size: 0.88rem; font-weight: 600; color: var(--color-text); }

/* Question block builder */
.questions-builder-container {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-height: 380px;
    overflow-y: auto;
    padding-right: 2px;
}
.question-block {
    border: 1.5px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1rem 1.1rem 0.9rem;
    background: var(--glass-bg);
    position: relative;
    transition: border-color 0.2s, box-shadow 0.2s;
}
.question-block:hover { border-color: var(--color-primary); box-shadow: 0 2px 8px rgba(87,120,90,0.08); }
.question-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
}
.question-block-num {
    font-size: 0.78rem; font-weight: 800; color: var(--color-primary);
    text-transform: uppercase; letter-spacing: 0.06em;
}
.question-count-badge {
    font-size: 0.83rem; font-weight: 700;
    color: var(--color-primary);
    background: rgba(87,120,90,0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
}
.correct-answer-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.6rem;
}
.correct-opt {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    cursor: pointer;
    padding: 0.28rem 0.65rem;
    border-radius: 0.45rem;
    border: 1.5px solid var(--color-border);
    background: var(--color-bg);
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-text);
    transition: all 0.15s;
}
.correct-opt:has(input:checked) {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
}
.correct-opt input[type="radio"] { display: none; }
.question-points-input {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.5rem;
}
.question-points-input label {
    font-size: 0.8rem; font-weight: 700;
    color: var(--color-text-secondary); white-space: nowrap;
}

/* Summary card (right side) */
.cefp-summary-card {
    background: var(--glass-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 0.85rem;
    padding: 1.2rem;
    position: sticky;
    top: 1rem;
}
.cefp-summary-title {
    font-size: 0.85rem; font-weight: 700;
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
    padding-bottom: 0.5rem;
    border-bottom: 1.5px solid var(--color-border);
}
.cefp-summary-stat { margin-bottom: 0.4rem; }
.ces-lbl { font-size: 0.7rem; font-weight: 700; color: var(--color-text-secondary); text-transform: uppercase; display: block; line-height: 1.2; }
.ces-val { font-size: 0.92rem; font-weight: 700; color: var(--color-text); }
.cefp-summary-stat-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
}
.cefp-summary-divider {
    border-top: 1px solid var(--color-border);
    margin: 0.7rem 0;
}
.cefp-summary-big {
    text-align: center;
    padding: 0.3rem 0;
}
.ces-big-num { font-size: 2rem; font-weight: 800; color: var(--color-primary); line-height: 1; }
.ces-big-lbl { font-size: 0.72rem; font-weight: 600; color: var(--color-text-secondary); text-transform: uppercase; }
.cefp-summary-options { display: flex; flex-wrap: wrap; gap: 0.3rem; }
.ces-opt-pill {
    font-size: 0.7rem; font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
    background: rgba(150,150,150,0.1);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
}
.ces-opt-pill.on { background: rgba(87,120,90,0.12); color: var(--color-primary); border-color: rgba(87,120,90,0.3); }

/* === RESPONSIVE: Exam === */
@media (max-width: 900px) {
    .exam-workspace { flex-direction: column; align-items: stretch; }
    .exam-navigation-panel { width: 100%; }
    .questions-grid-container { grid-template-columns: repeat(10, 1fr); }
    .cefp-grid { grid-template-columns: 1fr; }
    .cefp-summary-col { order: -1; }
}
@media (max-width: 600px) {
    .exam-main-panel { flex-direction: column; padding: 1rem; }
    .exam-info-card {
        width: 100%; border-right: none;
        border-bottom: 1.5px solid var(--color-border);
        padding-right: 0; padding-bottom: 1rem; margin-bottom: 1rem;
        display: flex; align-items: center; gap: 1.5rem;
    }
    .candidate-photo { margin: 0; }
    .questions-grid-container { grid-template-columns: repeat(5, 1fr); }
}

/* === @media print — PDF Score Report === */
@media print {
    body * { visibility: hidden; }
    #resultsPage, #resultsPage * { visibility: visible; }
    #resultsPage {
        position: fixed !important;
        inset: 0 !important;
        background: white !important;
        backdrop-filter: none !important;
        display: flex !important;
        align-items: flex-start !important;
        padding: 2rem !important;
    }
    .results-outer-scroll { max-height: none !important; overflow: visible !important; }
    .results-container { box-shadow: none !important; border: none !important; width: 100% !important; padding: 0 !important; }
    .answer-review-list { max-height: none !important; overflow: visible !important; }
    #backToDashboard, #downloadPdfBtn, #practiceAgainBtn, .results-actions { display: none !important; }
    .score-ring-fill { stroke: #333 !important; }
    .pass-badge.badge-pass { border-color: #2d6a2d !important; color: #2d6a2d !important; background: #e8f5e9 !important; }
    .pass-badge.badge-fail { border-color: #c0392b !important; color: #c0392b !important; background: #fdecea !important; }
}

/* --- Legacy fonts override --- */
.dashboard, .exam-interface, .results-page, .results-container,
.exam-card, .stat-card, .student-stats-card, .recent-result-item,
.result-item, .exam-title, .exam-meta, .exam-detail,
.stat-label, .stat-value, .result-label, .result-score,
.question-title, .question-text, .option-item {
  font-family: 'Inter', sans-serif !important;
}
