# FetenaX .htaccess — InfinityFree / Apache configuration

# Disable directory listing (security)
Options -Indexes

# Default charset
AddDefaultCharset UTF-8

# ──────────────────────────────────────────────────
# Application config
# Public student self-signup is DISABLED by default.
# Students must be created by a teacher via the
# "Register Student" button or CSV bulk-import.
# To RE-ENABLE self-signup, comment out the next line
# OR change it to: SetEnv ALLOW_SIGNUP true
# ──────────────────────────────────────────────────
SetEnv ALLOW_SIGNUP false

# Enable URL rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# CRITICAL: Allow access to index.php and api.php — these are the ONLY entry points
# Do NOT block api.php — it's the API endpoint the frontend calls
<FilesMatch "\.(sql|csv|md|env|log|ini)$">
    Require all denied
</FilesMatch>

# Block hidden files except .htaccess
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<Files ".htaccess">
    Require all granted
</Files>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 day"
    ExpiresByType application/javascript "access plus 1 day"
    ExpiresByType text/javascript "access plus 1 day"
    ExpiresByType image/png "access plus 7 days"
    ExpiresByType image/jpeg "access plus 7 days"
    ExpiresByType image/gif "access plus 7 days"
    ExpiresByType image/svg+xml "access plus 7 days"
    ExpiresByType application/manifest+json "access plus 1 hour"
    ExpiresByType application/json "access plus 1 hour"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PWA — serve manifest.json with the correct MIME type
<IfModule mod_mime.c>
    AddType application/manifest+json .json
    AddType application/javascript .js
    AddType text/cache-manifest .appcache
</IfModule>

# Allow service worker scope = root (so it can intercept all requests)
<IfModule mod_headers.c>
    <Files "sw.js">
        Header set Service-Worker-Allowed "/"
    </Files>
</IfModule>

# PHP settings
<IfModule mod_php7.c>
    php_value display_errors Off
    php_value log_errors On
    php_value max_execution_time 120
    php_value upload_max_filesize 30M
    php_value post_max_size 32M
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite Lax
    php_value session.gc_maxlifetime 2592000
</IfModule>
<IfModule mod_php.c>
    php_value display_errors Off
    php_value log_errors On
    php_value max_execution_time 120
    php_value upload_max_filesize 30M
    php_value post_max_size 32M
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite Lax
    php_value session.gc_maxlifetime 2592000
</IfModule>

# Error pages
ErrorDocument 403 /index.php
ErrorDocument 404 /index.php
